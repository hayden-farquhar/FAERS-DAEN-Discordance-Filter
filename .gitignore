# --- Runtime-generated analysis outputs (regenerated by the scripts) ---
# The pipeline writes intermediate parquet + result files here. The committed
# reference copies of the reportable results live in outputs/.
results/

# Generated figure renders (PNG/SVG). The .mmd source and reference renders are
# committed under outputs/figures/.
figures/*.png
figures/*.svg

# --- Raw data (NOT redistributable; see data/raw/README.md) ---
data/raw/*
!data/raw/README.md
data/faers/
data/daen/

# --- Secrets ---
.env

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.venv/
venv/

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
